@model KitabeviMVC.Models.ViewModels.KitapFormViewModel

@{
    ViewData["Title"] = "Yeni Kitap Ekle";
}

<h2>Yeni Kitap Ekle</h2>

@* asp-action → action="/kitaplar/ekle" otomatik üretilir
   Anti-forgery token gizli alan olarak forma eklenir *@
<form asp-controller="Kitap" asp-action="Ekle" method="post" style="max-width: 500px;">
    @Html.AntiForgeryToken()

    @* asp-validation-summary → ModelState'teki model seviyesi hataları gösterir
       "ModelOnly" → sadece belirli bir alana bağlı olmayan hataları gösterir *@
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        @* asp-for="Baslik" → label için "for" attribute'unu, input için
           "id", "name" ve mevcut değeri otomatik doldurur *@
        <label asp-for="Baslik" class="form-label"></label>
        <input asp-for="Baslik" class="form-control" placeholder="Kitap başlığı" />
        @* asp-validation-for → bu alana ait ModelState hatalarını gösterir *@
        <span asp-validation-for="Baslik" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Yazar" class="form-label"></label>
        <input asp-for="Yazar" class="form-control" placeholder="Yazar adı" />
        <span asp-validation-for="Yazar" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Kategori" class="form-label"></label>
        @* select — asp-for bağladığında mevcut değeri otomatik seçili gösterir *@
        <select asp-for="Kategori" class="form-select">
            <option value="">-- Seçiniz --</option>
            <option>Roman</option>
            <option>Tarih</option>
            <option>Kişisel</option>
            <option>Bilim</option>
            <option>Teknik</option>
        </select>
        <span asp-validation-for="Kategori" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Fiyat" class="form-label"></label>
        @* type="number" + step → tarayıcı ondalıklı sayı kabul eder *@
        <input asp-for="Fiyat" class="form-control" type="number" step="0.01" min="0" />
        <span asp-validation-for="Fiyat" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="StokAdedi" class="form-label"></label>
        <input asp-for="StokAdedi" class="form-control" type="number" min="0" />
        <span asp-validation-for="StokAdedi" class="text-danger small"></span>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Kaydet</button>
        <a asp-controller="Kitap" asp-action="Liste" class="btn btn-outline-secondary">İptal</a>
    </div>
</form>

@* Client-side validation için jquery.validate kütüphanesi gerekli.
   _ValidationScriptsPartial bu kütüphaneyi yükler.
   Olmadan form submit'e kadar hata görünmez — sunucu validation hâlâ çalışır. *@
@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
