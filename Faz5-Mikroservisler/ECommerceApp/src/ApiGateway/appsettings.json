{
  "ReverseProxy": {
    "Routes": {
      "product-route": {
        "ClusterId": "product-cluster",
        "Match": { "Path": "/api/products/{**catch-all}" }
      },
      "order-route": {
        "ClusterId": "order-cluster",
        "Match": { "Path": "/api/orders/{**catch-all}" }
      }
    },
    "Clusters": {
      "product-cluster": {
        "Destinations": {
          "product-service": { "Address": "http://product-service:8080/" }
        }
      },
      "order-cluster": {
        "Destinations": {
          "order-service": { "Address": "http://order-service:8080/" }
        }
      }
    }
  }
}
